    python3 NEXUS_OS_v3.py status
    python3 NEXUS_OS_v3.py evolve
    python3 NEXUS_OS_v3.py code --desc "build a REST API"
    python3 NEXUS_OS_v3.py task --name "fix bug" --desc "API returns 500"
